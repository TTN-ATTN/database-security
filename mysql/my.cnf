# DEPRECATED on WSL2 Windows filesystem mounts.
#
# Bind-mounting this file into /etc/mysql/conf.d/ on WSL2 makes it world-writable
# (host filesystem keeps 0777 perms regardless of `chmod`), so MySQL refuses to
# read it ("World-writable config file ... is ignored").
#
# All settings have been moved into compose.yaml under `services.mysql.command`
# as `--flag=value` arguments, which bypasses the perms check entirely.
#
# Kept here as documentation of the intended MySQL configuration.

[mysqld]
performance_schema=ON
skip_name_resolve=ON
local_infile=0
max_connections=200

# Phase 3 - Active Monitor
general_log=ON
general_log_file=/var/log/mysql/general.log
slow_query_log=ON
slow_query_log_file=/var/log/mysql/slow.log
long_query_time=0.5
log_output=FILE
