# Phase 1 demo credentials. Copy this file to .env before running Docker Compose.

MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=testdb
MYSQL_APP_USER=appuser
MYSQL_APP_PASSWORD=apppass

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# Host-side ports. MySQL defaults to 3307 to avoid conflicts with local MySQL.
MYSQL_HOST_PORT=3307
MYSQLD_EXPORTER_HOST_PORT=9104
PROMETHEUS_HOST_PORT=9090
ALERTMANAGER_HOST_PORT=9093
GRAFANA_HOST_PORT=3000

# Phase 4 - Database Firewall (ProxySQL). Credentials below are demo values and must
# match config/proxysql/proxysql.cnf and mysql/proxysql-users.sql.
PROXYSQL_CLIENT_HOST_PORT=6033
PROXYSQL_ADMIN_HOST_PORT=6032
# 'admin' is loopback-only in ProxySQL; 'radmin' is the remote-capable admin account.
PROXYSQL_ADMIN_USER=radmin
PROXYSQL_ADMIN_PASSWORD=radmin
DBF_USER=dbfuser
DBF_PASSWORD=dbfpass

# Phase 4 - Acra transparent encryption (evaluation path, optional).
ACRA_SERVER_HOST_PORT=9393
# ACRA_MASTER_KEY is generated by scripts/phase4_acra_keys.sh and appended to .env.
# Do not set it by hand; leave unset until the key script runs.
