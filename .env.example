# Phase 1 demo credentials. Copy this file to .env before running Docker Compose.

MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=testdb
MYSQL_APP_USER=appuser
MYSQL_APP_PASSWORD=apppass

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# Host-side ports. MySQL defaults to 3307 to avoid conflicts with local MySQL.
MYSQL_HOST_PORT=3307
MYSQLD_EXPORTER_HOST_PORT=9104
PROMETHEUS_HOST_PORT=9090
ALERTMANAGER_HOST_PORT=9093
GRAFANA_HOST_PORT=3000
