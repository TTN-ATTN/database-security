# Normalize line endings to LF on commit and on checkout, regardless of host OS.
# This project's runtime is Linux (Docker containers + WSL), so LF is required.
# Windows-only file types (.bat/.cmd/.ps1) are kept as CRLF for native tooling.

* text=auto eol=lf

# Shell, config, and data-language files - LF always.
*.sh        text eol=lf
*.bash      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sql       text eol=lf
*.py        text eol=lf
*.cnf       text eol=lf
*.conf      text eol=lf
*.toml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.env       text eol=lf
.env*       text eol=lf
.gitignore  text eol=lf
Makefile    text eol=lf
Dockerfile* text eol=lf

# Windows-native scripts - keep CRLF.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary files - never touch.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
